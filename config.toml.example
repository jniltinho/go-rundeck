[server]
name           = "Go-Rundeck"
env            = "development"      # development | production
port           = 8080
debug          = true
ssl_enable     = false
# ssl_cert = "ssl/server.crt"
# ssl_key  = "ssl/server.key"
# If both cert and key are provided, SSL will be enabled automatically
# Generate a random 64-character hex string for production use, e.g.: openssl rand -hex 32
session_secret  = "CHANGE_ME_SECRET_64CHARS_HEX_STRING_HERE"
session_timeout = 60 # inactivity timeout in minutes

[database]
host     = "localhost"
port     = 3306
user     = "rundeck"
password = "rundeck_pass"
name     = "gorundeck"
charset  = "utf8mb4"

[ssh]
default_user       = "deploy"
default_port       = 22
connect_timeout    = 10      # in seconds
key_storage_path   = "./keys"

[scheduler]
enabled            = true
check_interval     = 30      # in seconds

[log]
level  = "info"      # debug | info | warn | error
format = "json"      # json | text
output = "stdout"    # stdout | file path (e.g., /var/log/gorundeck.log)
